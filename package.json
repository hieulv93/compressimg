{
  "name": "image-compressor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "generate-og": "node scripts/generate-og.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "gif.js": "^0.2.0",
    "gifuct-js": "^2.1.2",
    "heic2any": "^0.0.4",
    "jszip": "^3.10.1",
    "next": "14.2.35",
    "next-sitemap": "^4.2.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,css}": "prettier --write"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
